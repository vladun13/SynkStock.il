# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_inventory,read_orders,read_locations

# App
HOST=https://your-tunnel.trycloudflare.com
PORT=3000
NODE_ENV=development

# Demo / test
DEMO_MODE=true
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,https://your-admin.vercel.app,https://your-scanner.vercel.app,https://your-landing.vercel.app
TEST_DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# Odoo (optional)
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=
